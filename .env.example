# ── Trello ───────────────────────────────────────────────────────────────────
# 1. API key:   https://trello.com/power-ups/admin  →  open/create a Power-Up
#               →  "API Key" tab  →  Generate a new API Key.  Paste it below.
TRELLO_API_KEY=
# 2. Token:     visit this URL (substitute YOUR key) and click "Allow",
#               then paste the token Trello shows you:
#    https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&name=trellowrapper&key=YOUR_API_KEY
TRELLO_TOKEN=
# 3. Board:     paste the board's short id OR its full URL
#               (e.g. https://trello.com/b/AbCdEfGh/my-board  →  AbCdEfGh is fine).
#               The board can be empty — I'll create the pipeline lists/label for you.
TRELLO_BOARD_ID=

# ── Telegram ─────────────────────────────────────────────────────────────────
# 4. Bot token: message @BotFather  →  /newbot  →  follow prompts  →  paste token.
TELEGRAM_BOT_TOKEN=
# 5. Chat id:   message YOUR new bot anything (e.g. /start). Leave this blank —
#               I'll fetch it via getUpdates once the bot token is set. Or get it
#               from @userinfobot and paste it here.
TELEGRAM_CHAT_ID=

# ── Anthropic ────────────────────────────────────────────────────────────────
# Worker auth. With normal Claude Code auth the daemon can run `claude` without
# this; for `--bare` headless runs an API key is required. Paste if you have one.
ANTHROPIC_API_KEY=

# ── First target repo ────────────────────────────────────────────────────────
# A repo you own/trust (Phase 1 runs locally, PR-only). Absolute path + commands.
TARGET_REPO=                       # e.g. AlikhanMussabekov/somerepo
TARGET_REPO_PATH=                  # e.g. /Users/alikhanmussabekov/Projects/somerepo
TARGET_TEST_CMD=npm test
TARGET_LINT_CMD=npm run lint
TARGET_BUILD_CMD=npm run build
